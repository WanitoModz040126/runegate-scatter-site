# Same value as the admin-site's DATABASE_URL -- both services MUST point
# at the exact same PostgreSQL database.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Long random string, different from admin-site's SESSION_SECRET.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

NODE_ENV=production
PORT=3000

# Set to "false" only if your Postgres provider doesn't support/require SSL.
PGSSL=true
